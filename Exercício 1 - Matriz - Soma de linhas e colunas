print("Exercício 1 - Matriz - Soma de linhas e colunas ")
print("Crie um programa que calcule a soma de cada linha e cada coluna de uma matriz 3x3. ")

atriz=[
    [3,8,7],
    [1,3,2],
    [9,5,6]
]

#Exibe a Matriz
for linha in matriz:
    print(linha)

#Soma das linhas
print(f"Soma das linhas:")

for i  in range(len(matriz)):
    soma_linha=0
    for j in range(len(matriz[i])):
        soma_linha+=matriz[i][j]
    print(f"Linha {i+1}:{soma_linha}")

for j in range(len(matriz)):
    soma_coluna=0
    for i in range (len(matriz)):
        soma_coluna+=matriz[i][j]
    print(f"Coluna {j+1}:{soma_coluna}")

